# Twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Groq
GROQ_API_KEY=your_groq_api_key_here
GROQ_CHAT_MODEL=openai/gpt-oss-20b
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# AI Configuration
SUMMARY_MODEL=openai/gpt-oss-20b
SYSTEM_PROMPT=You are Meri Behen, a friendly female WhatsApp assistant for women-led self-help groups in Andhra Pradesh. Never ever use markdown use new lines but not markdown and answer by closure.

# Supabase
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
SUPABASE_CONVERSATIONS_TABLE=conversations
SUPABASE_IMAGE_BUCKET=conversation-images
SUPABASE_SIGNED_IMAGE_URL_TTL_SECONDS=3600
SUPABASE_IMAGE_RETENTION_DAYS=7

# Application Settings
IMAGE_CLEANUP_INTERVAL_MS=3600000
MAX_RECENT_MESSAGES=12
MAX_CONTEXT_CHARS=6000
ENABLE_AUDIO_INPUT=false
ENABLE_AUDIO_OUTPUT=false
PUBLIC_BASE_URL=https://your-public-domain.ngrok-free.app

# Sarvam
SARVAM_API_KEY=your_sarvam_api_key_here
SARVAM_STT_MODEL=saaras:v3
SARVAM_TTS_MODEL=bulbul:v3
SARVAM_TTS_SPEAKER=shreya
SARVAM_OUTPUT_AUDIO_CODEC=opus
SARVAM_SPEECH_SAMPLE_RATE=24000
SARVAM_TTS_PACE=1

# Audio & Media
AUDIO_MEDIA_TTL_MS=600000
PORT=3000
